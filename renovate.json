{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "addLabels": [
    "renovate"
  ],
  "major": {
    "dependencyDashboardApproval": true
  },
  "description": [
    "ignorePaths mirrors the config:recommended defaults but drops **/tests/**.",
    "Custom managers cannot see files under tests/ while that entry is active,",
    "which would silently disable the DockerImages.cs manager below.",
    "Re-check this list when config:recommended changes its own defaults."
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/examples/**",
    "**/__tests__/**",
    "**/test/**",
    "**/__fixtures__/**"
  ],
  "packageRules": [
    {
      "description": "Restore old NuGet update behavior for bare versions",
      "matchManagers": [
        "nuget"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Allow FluentAssertions updates within v7 only",
      "matchPackageNames": [
        "FluentAssertions"
      ],
      "allowedVersions": "<8"
    },
    {
      "groupName": "Test SDK/MTP",
      "matchPackageNames": [
        "Microsoft.NET.Test.Sdk",
        "Microsoft.TestPlatform.TestHost",
        "Microsoft.Testing.Platform",
        "Microsoft.Testing.Extensions.CodeCoverage"
      ]
    },
    {
      "groupName": "xunit",
      "matchPackageNames": [
        "xunit.v3.mtp-v2",
        "xunit.runner.visualstudio"
      ]
    },
    {
      "groupName": "RabbitMQ",
      "matchPackageNames": [
        "RabbitMQ.Client",
        "Testcontainers.RabbitMq",
        "rabbitmq"
      ]
    },
    {
      "groupName": "NATS",
      "matchPackageNames": [
        "NATS.Net",
        "Testcontainers.Nats",
        "nats"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update the dotnet-reportgenerator-globaltool version pinned in CI workflows",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "dotnet-reportgenerator-globaltool\\s+--version\\s+(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "dotnet-reportgenerator-globaltool",
      "datasourceTemplate": "nuget"
    },
    {
      "customType": "regex",
      "description": "Update the Docker images pinned in the Testcontainers DockerImages constants",
      "managerFilePatterns": [
        "**/TestSupport/DockerImages.cs"
      ],
      "matchStrings": [
        "public const string \\w+ = \"(?<depName>[a-z0-9][a-z0-9._-]*):(?<currentValue>[a-zA-Z0-9][a-zA-Z0-9._-]*)\";"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
